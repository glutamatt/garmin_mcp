# Functional test credentials — copy to .env and fill in
# .env is gitignored, safe to put real credentials there

# Read-only account (your real account with actual data)
GARMIN_EMAIL_READONLY=
GARMIN_PASSWORD_READONLY=

# Dev account (test account where write tests can create/delete data)
GARMIN_EMAIL_DEV=
GARMIN_PASSWORD_DEV=
